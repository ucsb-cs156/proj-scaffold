{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "007-create-sections-table",
        "author": "pc",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "not": { "tableExists": { "tableName": "sections" } } }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "sections",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "BIGINT",
                    "autoIncrement": true,
                    "constraints": { "nullable": false, "primaryKey": true }
                  }
                },
                {
                  "column": {
                    "name": "course_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "section",
                    "type": "VARCHAR(255)",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "label",
                    "type": "VARCHAR(255)",
                    "constraints": { "nullable": false }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
