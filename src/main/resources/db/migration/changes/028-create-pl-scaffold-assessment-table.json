{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "028-create-pl-scaffold-assessment-table",
        "author": "copilot",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "not": { "tableExists": { "tableName": "pl_scaffold_assessment" } } }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "pl_scaffold_assessment",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "BIGINT",
                    "autoIncrement": true,
                    "constraints": { "nullable": false, "primaryKey": true }
                  }
                },
                {
                  "column": {
                    "name": "pl_repo_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "pl_instance_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "pl_question_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "status",
                    "type": "VARCHAR(255)",
                    "constraints": { "nullable": false }
                  }
                },
                { "column": { "name": "url", "type": "VARCHAR(255)" } }
              ]
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "pl_scaffold_assessment",
              "baseColumnNames": "pl_repo_id",
              "referencedTableName": "pl_repo",
              "referencedColumnNames": "id",
              "constraintName": "FK_PL_SCAFFOLD_ASSESSMENT_PL_REPO_ID"
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "pl_scaffold_assessment",
              "baseColumnNames": "pl_instance_id",
              "referencedTableName": "pl_instance",
              "referencedColumnNames": "id",
              "constraintName": "FK_PL_SCAFFOLD_ASSESSMENT_PL_INSTANCE_ID"
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "pl_scaffold_assessment",
              "baseColumnNames": "pl_question_id",
              "referencedTableName": "pl_question",
              "referencedColumnNames": "id",
              "constraintName": "FK_PL_SCAFFOLD_ASSESSMENT_PL_QUESTION_ID"
            }
          },
          {
            "addUniqueConstraint": {
              "tableName": "pl_scaffold_assessment",
              "columnNames": "pl_repo_id, pl_instance_id, pl_question_id",
              "constraintName": "UQ_PL_SCAFFOLD_ASSESSMENT_REPO_INSTANCE_QUESTION"
            }
          }
        ]
      }
    }
  ]
}
