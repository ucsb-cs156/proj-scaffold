      "changeSet": {
        "id": "000-create-assessments",
        "author": "copilot",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "not": { "tableExists": { "tableName": "assessments" } } }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "assessments",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "UUID",
                    "constraints": { "nullable": false, "primaryKey": true }
                  }
                },
                { "column": { "name": "pl_assessment_id", "type": "VARCHAR(255)" } },
                {
                  "column": {
                    "name": "name",
                    "type": "VARCHAR(255)",
                    "constraints": { "nullable": false }
                  }
                }
              ]
            }
          }
        ]
      }
    },
