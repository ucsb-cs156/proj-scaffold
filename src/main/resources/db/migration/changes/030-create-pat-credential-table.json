{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "030-create-pat-credential-table",
        "author": "claude",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "not": { "tableExists": { "tableName": "pat_credential" } } }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "pat_credential",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "BIGINT",
                    "autoIncrement": true,
                    "constraints": { "nullable": false, "primaryKey": true }
                  }
                },
                {
                  "column": {
                    "name": "user_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false, "unique": true }
                  }
                },
                {
                  "column": {
                    "name": "ciphertext",
                    "type": "VARCHAR(512)",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "key_version",
                    "type": "INT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "last_four",
                    "type": "VARCHAR(4)",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "expires_at",
                    "type": "DATE"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
