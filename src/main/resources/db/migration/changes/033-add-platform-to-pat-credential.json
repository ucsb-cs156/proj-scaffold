{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "033-add-platform-column",
        "author": "claude",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          {
            "not": {
              "columnExists": {
                "tableName": "pat_credential",
                "columnName": "platform"
              }
            }
          }
        ],
        "changes": [
          {
            "addColumn": {
              "tableName": "pat_credential",
              "columns": [
                {
                  "column": {
                    "name": "platform",
                    "type": "VARCHAR(20)",
                    "defaultValue": "GITHUB",
                    "constraints": { "nullable": false }
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "033-drop-user-id-unique-postgresql",
        "author": "claude",
        "dbms": "postgresql",
        "changes": [
          {
            "dropUniqueConstraint": {
              "tableName": "pat_credential",
              "constraintName": "pat_credential_user_id_key"
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "033-drop-user-id-unique-h2",
        "author": "claude",
        "dbms": "h2",
        "changes": [
          {
            "sql": {
              "sql": "ALTER TABLE pat_credential DROP CONSTRAINT IF EXISTS CONSTRAINT_D"
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "033-add-user-platform-unique",
        "author": "claude",
        "changes": [
          {
            "addUniqueConstraint": {
              "tableName": "pat_credential",
              "columnNames": "user_id, platform",
              "constraintName": "uq_pat_credential_user_platform"
            }
          }
        ]
      }
    }
  ]
}
