{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "003-rename-student-userids-primary-key-constraint",
        "author": "copilot",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "dbms": { "type": "postgresql" } },
          { "tableExists": { "tableName": "student_userids" } }
        ],
        "changes": [
          {
            "sql": {
              "splitStatements": false,
              "stripComments": true,
              "sql": "DO $$ BEGIN IF EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'student_pins_pkey') THEN ALTER TABLE student_userids RENAME CONSTRAINT student_pins_pkey TO student_userids_pkey; END IF; END $$;"
            }
          }
        ]
      }
    }
  ]
}
