{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "042-create-pl-assessment-question-concept-table",
        "author": "pc",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "not": { "tableExists": { "tableName": "pl_assessment_question_concept" } } }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "pl_assessment_question_concept",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "BIGINT",
                    "autoIncrement": true,
                    "constraints": { "nullable": false, "primaryKey": true }
                  }
                },
                {
                  "column": {
                    "name": "pl_assessment_question_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "concept_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                }
              ]
            }
          },
          {
            "addUniqueConstraint": {
              "tableName": "pl_assessment_question_concept",
              "columnNames": "pl_assessment_question_id, concept_id",
              "constraintName": "UK_PL_ASSESSMENT_QUESTION_CONCEPT"
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "pl_assessment_question_concept",
              "baseColumnNames": "pl_assessment_question_id",
              "referencedTableName": "pl_assessment_question",
              "referencedColumnNames": "id",
              "constraintName": "FK_PAQC_PL_ASSESSMENT_QUESTION_ID",
              "onDelete": "CASCADE"
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "pl_assessment_question_concept",
              "baseColumnNames": "concept_id",
              "referencedTableName": "concepts",
              "referencedColumnNames": "id",
              "constraintName": "FK_PAQC_CONCEPT_ID",
              "onDelete": "CASCADE"
            }
          }
        ]
      }
    }
  ]
}
