{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "001-rename-student-pins-table",
        "author": "copilot",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "tableExists": { "tableName": "student_pins" } },
          { "not": { "tableExists": { "tableName": "student_userids" } } }
        ],
        "changes": [
          {
            "renameTable": {
              "oldTableName": "student_pins",
              "newTableName": "student_userids"
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "001-rename-student-userid-column",
        "author": "copilot",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "tableExists": { "tableName": "student_userids" } },
          { "columnExists": { "tableName": "student_userids", "columnName": "pin" } },
          { "not": { "columnExists": { "tableName": "student_userids", "columnName": "userid" } } }
        ],
        "changes": [
          {
            "renameColumn": {
              "tableName": "student_userids",
              "oldColumnName": "pin",
              "newColumnName": "userid",
              "columnDataType": "VARCHAR(255)"
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "001-rename-user-state-column",
        "author": "copilot",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "tableExists": { "tableName": "user_state" } },
          { "columnExists": { "tableName": "user_state", "columnName": "pin" } },
          { "not": { "columnExists": { "tableName": "user_state", "columnName": "userid" } } }
        ],
        "changes": [
          {
            "renameColumn": {
              "tableName": "user_state",
              "oldColumnName": "pin",
              "newColumnName": "userid",
              "columnDataType": "VARCHAR(255)"
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "001-rename-user-activity-column",
        "author": "copilot",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "tableExists": { "tableName": "user_activity" } },
          { "columnExists": { "tableName": "user_activity", "columnName": "pin" } },
          { "not": { "columnExists": { "tableName": "user_activity", "columnName": "userid" } } }
        ],
        "changes": [
          {
            "renameColumn": {
              "tableName": "user_activity",
              "oldColumnName": "pin",
              "newColumnName": "userid",
              "columnDataType": "VARCHAR(255)"
            }
          }
        ]
