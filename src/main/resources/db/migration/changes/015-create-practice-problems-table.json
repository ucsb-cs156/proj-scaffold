{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "015-create-practice-problems-table",
        "author": "pc",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "not": { "tableExists": { "tableName": "practice_problems" } } }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "practice_problems",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "BIGINT",
                    "autoIncrement": true,
                    "constraints": { "nullable": false, "primaryKey": true }
                  }
                },
                {
                  "column": {
                    "name": "course_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "concept_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "url",
                    "type": "VARCHAR(512)",
                    "constraints": { "nullable": false }
                  }
                }
              ]
            }
          },
          {
            "addUniqueConstraint": {
              "tableName": "practice_problems",
              "columnNames": "course_id, concept_id, url",
              "constraintName": "UK_PRACTICE_PROBLEMS_COURSE_CONCEPT_URL"
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "practice_problems",
              "baseColumnNames": "course_id",
              "referencedTableName": "course",
              "referencedColumnNames": "id",
              "constraintName": "FK_PRACTICE_PROBLEMS_COURSE_ID"
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "practice_problems",
              "baseColumnNames": "concept_id",
              "referencedTableName": "concepts",
              "referencedColumnNames": "id",
              "constraintName": "FK_PRACTICE_PROBLEMS_CONCEPT_ID"
            }
          }
        ]
      }
    }
  ]
}
