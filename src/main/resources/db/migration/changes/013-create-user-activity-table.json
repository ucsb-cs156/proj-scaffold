{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "013-create-user-activity-table",
        "author": "pc",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "not": { "tableExists": { "tableName": "user_activity" } } }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "user_activity",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "UUID",
                    "constraints": { "nullable": false, "primaryKey": true }
                  }
                },
                {
                  "column": {
                    "name": "userid",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "event_type",
                    "type": "VARCHAR(255)",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "payload",
                    "type": "TEXT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "created_at",
                    "type": "TIMESTAMP",
                    "constraints": { "nullable": false }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
