{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "018-create-user-activity-v2-table",
        "author": "pc",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "not": { "tableExists": { "tableName": "user_activity_v2" } } }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "user_activity_v2",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "UUID",
                    "constraints": { "nullable": false, "primaryKey": true }
                  }
                },
                {
                  "column": {
                    "name": "userid",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "course_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "event_type",
                    "type": "VARCHAR(255)",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "payload",
                    "type": "VARCHAR(1048576)",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "created_at",
                    "type": "TIMESTAMP",
                    "constraints": { "nullable": false }
                  }
                }
              ]
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "user_activity_v2",
              "baseColumnNames": "course_id",
              "referencedTableName": "course",
              "referencedColumnNames": "id",
              "constraintName": "FK_USER_ACTIVITY_V2_COURSE_ID"
            }
          }
        ]
      }
    }
  ]
}
