{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "011-create-question-concepts-table",
        "author": "pc",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "not": { "tableExists": { "tableName": "question_concepts" } } }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "question_concepts",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "UUID",
                    "constraints": { "nullable": false, "primaryKey": true }
                  }
                },
                {
                  "column": {
                    "name": "question_id",
                    "type": "UUID",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "concept_id",
                    "type": "VARCHAR(255)",
                    "constraints": { "nullable": false }
                  }
                },
                { "column": { "name": "subconcept_label", "type": "VARCHAR(255)" } }
              ]
            }
          }
        ]
      }
    }
  ]
}
