{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "016-create-concept-edges-table",
        "author": "pc",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "not": { "tableExists": { "tableName": "concept_edges" } } }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "concept_edges",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "BIGINT",
                    "autoIncrement": true,
                    "constraints": { "nullable": false, "primaryKey": true }
                  }
                },
                {
                  "column": {
                    "name": "course_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "source_concept_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "target_concept_id",
                    "type": "BIGINT",
                    "constraints": { "nullable": false }
                  }
                }
              ]
            }
          },
          {
            "addUniqueConstraint": {
              "tableName": "concept_edges",
              "columnNames": "source_concept_id, target_concept_id",
              "constraintName": "UK_CONCEPT_EDGES_SOURCE_TARGET"
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "concept_edges",
              "baseColumnNames": "course_id",
              "referencedTableName": "course",
              "referencedColumnNames": "id",
              "constraintName": "FK_CONCEPT_EDGES_COURSE_ID"
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "concept_edges",
              "baseColumnNames": "source_concept_id",
              "referencedTableName": "concepts",
              "referencedColumnNames": "id",
              "constraintName": "FK_CONCEPT_EDGES_SOURCE_ID"
            }
          },
          {
            "addForeignKeyConstraint": {
              "baseTableName": "concept_edges",
              "baseColumnNames": "target_concept_id",
              "referencedTableName": "concepts",
              "referencedColumnNames": "id",
              "constraintName": "FK_CONCEPT_EDGES_TARGET_ID"
            }
          }
        ]
      }
    }
  ]
}
