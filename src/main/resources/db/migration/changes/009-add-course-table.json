{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "009-add-course-table",
        "author": "pc",
        "preConditions": [
          { "onFail": "MARK_RAN" },
          { "not": { "tableExists": { "tableName": "course" } } }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "course",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "BIGINT",
                    "autoIncrement": true,
                    "constraints": { "nullable": false, "primaryKey": true }
                  }
                },
                { "column": { "name": "instructor_email", "type": "VARCHAR(255)" } },
                { "column": { "name": "course_name", "type": "VARCHAR(255)" } },
                { "column": { "name": "term", "type": "VARCHAR(255)" } },
                { "column": { "name": "school", "type": "VARCHAR(255)" } },
                { "column": { "name": "canvas_api_token", "type": "VARCHAR(255)" } },
                { "column": { "name": "canvas_course_id", "type": "VARCHAR(255)" } }
              ]
            }
          }
        ]
      }
    }
  ]
}
